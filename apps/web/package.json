{
  "name": "@vulf/web",
  "type": "module",
  "scripts": {
    "dev": "bun run migrate && bun run seed && bun run --parallel --no-exit-on-error dev:server worker",
    "dev:server": "bun --env-file=../../.env --bun vite --config vite.config.ts",
    "build": "bun --env-file=../../.env.production --bun vite build --config vite.config.ts",
    "start": "bun run .output/server/index.mjs",
    "worker": "bun --env-file=../../.env src/workers/runner.ts",
    "worker:prod": "bun src/workers/runner.ts",
    "migrate": "bun --env-file=../../.env src/lib/db/migrate-cli.ts",
    "migrate:test": "bun --env-file=../../.env.test src/lib/db/migrate-cli.ts",
    "migrate:prod": "bun src/lib/db/migrate-cli.ts",
    "seed": "bun --env-file=../../.env src/lib/db/seed.ts",
    "seed:test": "bun --env-file=../../.env.test src/lib/db/seed.ts",
    "seed:prod": "bun --env-file=../../.env.production src/lib/db/seed.ts",
    "check:types": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hapi/boom": "^10.0.1",
    "@libsql/client": "^0.17.3",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "2.0.0-alpha.2",
    "@whiskeysockets/baileys": "^7.0.0-rc11",
    "bullmq": "^5.76.8",
    "ioredis": "^5.10.1",
    "kysely": "^0.29.1",
    "kysely-turso": "^0.1.1",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@solidjs/vite-plugin-nitro-2": "0.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.2"
  }
}
