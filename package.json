{
  "name": "vulf",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel --no-exit-on-error dev:web dev:robot",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:robot": "uv run --directory apps/robot python -m robot.worker",
    "check": "bun run --parallel check:web check:robot",
    "check:web": "bun run --cwd apps/web check:types",
    "check:robot": "uv run --directory apps/robot mypy .",
    "test": "bun run --cwd apps/web test",
    "format": "oxfmt .",
    "lint": "oxlint --deny-warnings apps/web"
  },
  "devDependencies": {
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1"
  }
}
