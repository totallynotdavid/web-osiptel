{
  "name": "vulf",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "check": "bun run --cwd apps/web check:types",
    "test": "bun run --cwd apps/web test",
    "format": "oxfmt .",
    "lint": "oxlint --deny-warnings apps/web"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1"
  }
}
